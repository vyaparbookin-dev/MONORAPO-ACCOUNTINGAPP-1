{
  "name": "red-accounting-desktop",
  "version": "1.0.0",
  "description": "Desktop client for Red Accounting",
  "author": "Red Accounting Team",
  "main": "main.cjs",
  "type": "module",
  "dependencies": {
    "@react-oauth/google": "^0.13.4",
    "@repo/shared": "*",
    "axios": "^1.7.2",
    "better-sqlite3": "^12.6.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.11.6",
    "lucide-react": "^0.390.0",
    "pdfjs-dist": "^4.2.67",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "tesseract.js": "^5.1.0",
    "uuid": "^3.4.0",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.redaccounting.desktop",
    "productName": "Red Accounting Book",
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "YOUR_GITHUB_REPO_NAME"
      }
    ],
    "files": [
      "dist/**/*",
      "main.cjs",
      "main.js",
      "preload.js",
      "src/main/**/*",
      "package.json",
      "icon.ico"
    ],
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
